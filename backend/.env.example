NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/inventory_pos?schema=public"

# JWT (min 32 chars cada uno)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# CORS - separar múltiples orígenes con coma
CORS_ORIGINS=http://localhost:5173
